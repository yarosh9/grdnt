          "@type": "DefinedTerm", "name": "White", "colorCode": "#FFFFFF", "@id": "wd:Q23444", "description": "Чистота, невинность, стерильность, начало.",
          "hasPart": [
            { "@type": "CreativeWork", "name": "High key", "@id": "wd:Q16943521", "description": "light art style. Технический дескриптор для участков с минимальной плотностью кода." },
            { "@type": "Person", "name": "Kenya Hara", "@id": "wd:Q973509", "description": "Философское обоснование «белого» не как пустоты, а как предельной информационной емкости. Япония." },
            { "@type": "Person", "name": "Vladimir Weisberg", "@id": "wd:Q4106032", "description": "painter, master of 'white on white' painting, explored the metaphysical essence of light and form." },
