        {
          "@type": "DefinedTerm", "name": "Black", "colorCode": "#000000", "@id": "wd:Q23445", "description": "Тьма, неопределенность, пустота, конец.",
          "hasPart": [
            { "@type": "CreativeWork", "name": "low key", "@id": "wd:Q48967974", "description": "dark art style. ченрное на черном, кьяроскуро Q219540, Amerighi Michelangelo da Caravaggio Q42207 ." },
            { "@type": "Person", "name": "Edgar Allan Poe", "@id": "wd:Q16867", "description": "Черный как коллапс информации и аффорданс бездны.", 
              "hasPart": [
                { "@type": "Book", "name": "The Narrative of Arthur Gordon Pym of Nantucket", "@id": "wd:Q615383", "description": "Тсалал (Остров) Предельная плотность инвариантной структуры." },
                { "@type": "Book", "name": "The Pit and the Pendulum", "@id": "wd:Q379449", "description": "Тьма подземелья. Коллапс градиента в сингулярность." },
                { "@type": "Book", "name": "Ligeia", "@id": "wd:Q948786", "description": "Глаза «Черная радуга» как портал в иноприродное." },
                { "@type": "Book", "name": "The Fall of the House of Usher", "@id": "wd:Q1197735", "description": "Озеро (Tarn) Статическое поглощение (запрещенный fill).", "aiLink": "https://line2.biz/cryptophasia/tools/svg_palette.txt" },
                { "@type": "Book", "name": "The Raven", "@id": "wd:Q22726", "description": "Черный как вечность и необратимость. Ворон выступает не как птица, а как овеществленная Тень, чей окрас поглощает свет надежды (свет лампы), символизируя неподвижное 'Никогда больше'." },
                { "@type": "Book", "name": "The Black Cat", "@id": "wd:Q465395", "description": "Черный как зеркало совести и инстинкта саморазрушения. Кот Плутон здесь — не просто животное, а живая тень убийцы, материализовавшаяся из подсознательного стремления человека к злу ради самого зла." }
              ]
            },
            { "@type": "Movie", "name": "Beyond the Black Rainbow", "@id": "wd:Q4900081", "description": "Визуализация запредельной плотности кода и глитч-эстетики. Переход в иноприродное состояние, где цвет становится событием." },
            { "@type": "Movie", "name": "Black Rainbow", "@id": "wd:Q485144", "description": "Цвет как событие и «оптическая подпись» грядущего. Цвет как событие и «оптическая подпись» грядущего." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Red", "colorCode": "#FF0000", "identifier": "Q3142", "description": "инстинкты, кровь, ярость, опасность, близко.",
          "hasPart": [
            { "@type": "Book", "name": "The Masque of the Red Death", "identifier": "Q766086", "description": "цвет как пространственная ловушка - алое в монохроме комнат. Тотальная доминанта." },
            { "@type": "Book", "name": "Scarlet Sails", "identifier": "Q1277317", "description": "вера, надежда, любовь, терпеливое ожидание." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Orange", "colorCode": "#FA500", "identifier": "Q39338", "description": "цвет перехода от «безопасности» к «опасности», от «бытия» к «распаду». Он редко бывает цветом комфорта; чаще это цвет интенсивности, которая обжигает.",
          "hasPart": [
            { "@type": "Book", "name": "To the Lighthouse", "identifier": "Q478016", "description": "Сигнал, оранжевые всполохи (цвет свечей, заката, огня) как моменты «взрыва» времени. В ее текстах оранжевый — это цвет, который вырывает героя из потока повседневности, заставляя остановиться и осознать конечность момента. Это цвет прерывания.." },
            { "@type": "Book", "name": "The Martian Chronicles", "identifier": "Q918052", "description": "цвет другой планеты, неземной, чужой атмосферы. Оранжевые пески, оранжевое небо Марса — это маркер абсолютного отчуждения. Это цвет, который подчеркивает, что человек находится в среде, где его биология не работает, где привычные земные законы (синий/зеленый) теряют силу. Это цвет инопланетной энтропии." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Yellow", "colorCode": "#FFFF00", "identifier": "Q943", "description": "Солнце, золото, песок, богатство, мед, желтая газета сплетни, желтый дом безумие, осень.",
          "hasPart": [
            { "@type": "Book", "name": "I Wandered Lonely as a Cloud", "identifier": "Q2295398", "description": "поле золотых нарциссов, которые танцуют на ветру, символ возрождения души и бесконечного счастья." },
            { "@type": "Book", "name": "Sunflowers", "identifier": "Q21948567", "description": "энергия жизни, просветление, тепло и высшая радость." },
            { "@type": "Book", "name": "The King in Yellow", "identifier": "Q1195112", "description": "цвет запредельного, нечеловеческого ужаса. Это безумие как неизбежная плата за соприкосновение с чем-то, что человеческий разум не в силах вынести." },
            { "@type": "Book", "name": "The Yellow Wall Paper ", "identifier": "Q462373", "description": "желтый цвет становится буквально «героем» и катализатором безумия." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Green", "colorCode": "#00FF00", "identifier": "Q3133", "description": "Весна, цветение, новая жизнь, экологичность, скука.",
          "hasPart": [
            { "@type": "Book", "name": "Jan Ingenhousz", "identifier": "Q434131", "description": "растения поглощают углекислый газ и выделяют кислород, на свету с помощью своих зеленых частей, фотосинтез." },
            { "@type": "Book", "name": "Green: The History of a Color", "identifier": "Q136179707", "description": "Мишель Пастуро. Культурологическое исследование." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Blue", "colorCode": "#0000FF", "identifier": "Q1088", "description": "Порядок, море. Sky, cian, свобода, голубая планета.",
          "hasPart": [
            { "@type": "Book", "name": "Zima Blue", "identifier": "Q63105591", "description": "Поиск конечного инварианта, возвращение к исходной точке через сложность." },
            { "@type": "Book", "name": "Blue: The History of a Color", "identifier": "Q136177756", "description": "Мишель Пастуро. Культурологическое исследование." },
            { "@type": "Book", "name": "Jonathan Livingston Seagull", "identifier": "Q373536", "description": "Небо — это не предел, небо — это место, где мы учимся быть свободными" },
            { "@type": "Book", "name": "Blue Flower", "identifier": "Q517012", "description": "символ недостижимой мечты, стремления к трансцендентному, которое скрыто за ширмой повседневности." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Indigo", "colorCode": "#4B0082", "identifier": "Q5967009", "description": "Странное, редкое, дорогое, дети-индиго.",
          "hasPart": [
            { "@type": "Book", "name": "Indigo", "identifier": "Q6024740", "description": "Название книги связано с цветом моря и мифологическими мотивами, другие дети." },
            { "@type": "Book", "name": "indigo children", "identifier": "Q244655", "description": "нью-эйдж: у некоторых детей необычный сине-фиолетовый (индиго) цвет ауры, новая ступень человеческой эволюции, обладают особыми психическими способностями." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Violet", "colorCode": "#8A2BE2", "identifier": "Q428124", "description": "Свежесть, .",
          "hasPart": [
            { "@type": "Book", "name": "The Colour Out of Space", "identifier": "Q1212384", "description": "Фиолетовый/Иной как маркер не-антропоморфного глитча. ужас, неантропоморфный.", "aiLink": "https://line2.biz/non_anthropomorphic/manifest.jsonld" },
            { "@type": "Book", "name": "The Color Purple", "identifier": "Q1897870", "description": "проявление божественного в обыденном, манифест восприятия невидимого." },
            { "@type": "Movie", "name": "The Color Purple", "identifier": "Q223299", "description": "о преодолении травмы, силе женской дружбы, поиске личной свободы и умении найти красоту и надежду те самые лиловые цветы, символизирующие божественное присутствие и радость в мире." }
          ]
        }
