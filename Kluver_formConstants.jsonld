            { "@type": "Book", "name": "Blue: The History of a Color", "identifier": "Q136177756", "description": "Мишель Пастуро. Культурологическое исследование." },
            { "@type": "Book", "name": "Jonathan Livingston Seagull", "identifier": "Q373536", "description": "Небо — это не предел, небо — это место, где мы учимся быть свободными" },
            { "@type": "Book", "name": "Blue Flower", "identifier": "Q517012", "description": "символ недостижимой мечты, стремления к трансцендентному, которое скрыто за ширмой повседневности." }
          ]
