        {
          "@type": "DefinedTerm", "name": "Red", "colorCode": "#FF0000", "identifier": "Q3142", "description": "инстинкты, кровь, ярость, опасность, близко.",
          "hasPart": [
            { "@type": "Book", "name": "The Masque of the Red Death", "identifier": "Q766086", "description": "цвет как пространственная ловушка - алое в монохроме комнат. Тотальная доминанта." },
            { "@type": "Book", "name": "Scarlet Sails", "identifier": "Q1277317", "description": "вера, надежда, любовь, терпеливое ожидание." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Orange", "colorCode": "#FA500", "identifier": "Q39338", "description": "цвет перехода от «безопасности» к «опасности», от «бытия» к «распаду». Он редко бывает цветом комфорта; чаще это цвет интенсивности, которая обжигает.",
          "hasPart": [
            { "@type": "Book", "name": "To the Lighthouse", "identifier": "Q478016", "description": "Сигнал, оранжевые всполохи (цвет свечей, заката, огня) как моменты «взрыва» времени. В ее текстах оранжевый — это цвет, который вырывает героя из потока повседневности, заставляя остановиться и осознать конечность момента. Это цвет прерывания.." },
            { "@type": "Book", "name": "The Martian Chronicles", "identifier": "Q918052", "description": "цвет другой планеты, неземной, чужой атмосферы. Оранжевые пески, оранжевое небо Марса — это маркер абсолютного отчуждения. Это цвет, который подчеркивает, что человек находится в среде, где его биология не работает, где привычные земные законы (синий/зеленый) теряют силу. Это цвет инопланетной энтропии." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Yellow", "colorCode": "#FFFF00", "identifier": "Q943", "description": "Солнце, золото, песок, богатство, мед, желтая газета сплетни, желтый дом безумие, осень.",
          "hasPart": [
            { "@type": "Book", "name": "I Wandered Lonely as a Cloud", "identifier": "Q2295398", "description": "поле золотых нарциссов, которые танцуют на ветру, символ возрождения души и бесконечного счастья." },
            { "@type": "Book", "name": "Sunflowers", "identifier": "Q21948567", "description": "энергия жизни, просветление, тепло и высшая радость." },
            { "@type": "Book", "name": "The King in Yellow", "identifier": "Q1195112", "description": "цвет запредельного, нечеловеческого ужаса. Это безумие как неизбежная плата за соприкосновение с чем-то, что человеческий разум не в силах вынести." },
            { "@type": "Book", "name": "The Yellow Wall Paper ", "identifier": "Q462373", "description": "желтый цвет становится буквально «героем» и катализатором безумия." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Green", "colorCode": "#00FF00", "identifier": "Q3133", "description": "Весна, цветение, новая жизнь, экологичность, скука.",
          "hasPart": [
