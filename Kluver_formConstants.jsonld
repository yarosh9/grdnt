            { "@type": "Person", "name": "Edgar Allan Poe", "@id": "wd:Q16867", "description": "Черный как коллапс информации и аффорданс бездны.", 
              "hasPart": [
                { "@type": "Book", "name": "The Narrative of Arthur Gordon Pym of Nantucket", "@id": "wd:Q615383", "description": "Тсалал (Остров) Предельная плотность инвариантной структуры." },
                { "@type": "Book", "name": "The Pit and the Pendulum", "@id": "wd:Q379449", "description": "Тьма подземелья. Коллапс градиента в сингулярность." },
                { "@type": "Book", "name": "Ligeia", "@id": "wd:Q948786", "description": "Глаза «Черная радуга» как портал в иноприродное." },
                { "@type": "Book", "name": "The Fall of the House of Usher", "@id": "wd:Q1197735", "description": "Озеро (Tarn) Статическое поглощение (запрещенный fill).", "aiLink": "https://line2.biz/cryptophasia/tools/svg_palette.txt" },
                { "@type": "Book", "name": "The Raven", "@id": "wd:Q22726", "description": "Черный как вечность и необратимость. Ворон выступает не как птица, а как овеществленная Тень, чей окрас поглощает свет надежды (свет лампы), символизируя неподвижное 'Никогда больше'." },
                { "@type": "Book", "name": "The Black Cat", "@id": "wd:Q465395", "description": "Черный как зеркало совести и инстинкта саморазрушения. Кот Плутон здесь — не просто животное, а живая тень убийцы, материализовавшаяся из подсознательного стремления человека к злу ради самого зла." }
              ]
            },
            { "@type": "Movie", "name": "Beyond the Black Rainbow", "@id": "wd:Q4900081", "description": "Визуализация запредельной плотности кода и глитч-эстетики. Переход в иноприродное состояние, где цвет становится событием." },
            { "@type": "Movie", "name": "Black Rainbow", "@id": "wd:Q485144", "description": "Цвет как событие и «оптическая подпись» грядущего. Цвет как событие и «оптическая подпись» грядущего." }
          ]
