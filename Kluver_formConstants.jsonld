            { "@type": "Book", "name": "Green: The History of a Color", "identifier": "Q136179707", "description": "Мишель Пастуро. Культурологическое исследование." }
          ]
        },
        {
          "@type": "DefinedTerm", "name": "Blue", "colorCode": "#0000FF", "identifier": "Q1088", "description": "Порядок, море. Sky, cian, свобода, голубая планета.",
          "hasPart": [
